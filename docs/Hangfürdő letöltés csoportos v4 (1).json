    {
      "parameters": {
        "jsCode": "// =============================================\n// PARSER: mec_agenda\n// Kimenet: egységes struktúra\n// =============================================\nconst html = $json.data || '';\nconst sourceItem = $('Loop Over Items').item.json;\nconst sourceUrl  = sourceItem.source_url || '';\nconst sourceKey  = sourceItem.source_key || 'unknown';\nconst scrapeRunId = $('Get Run ID').first().json.body;\n\nfunction stripLeadingEquals(value) {\n  if (value === null || value === undefined) return value;\n  if (typeof value !== 'string') return value;\n  return value.replace(/^\\s*=\\s*/, '').trim();\n}\n\nfunction decodeHtml(str = '') {\n  return stripLeadingEquals(\n    str\n      .replace(/&#8211;/g, '–')\n      .replace(/&#8220;/g, '\\u201c')\n      .replace(/&#8221;/g, '\\u201d')\n      .replace(/&#038;/g, '&')\n      .replace(/&amp;/g, '&')\n      .replace(/&quot;/g, '\"')\n      .replace(/&#039;/g, \"'\")\n      .replace(/&nbsp;/g, ' ')\n      .trim()\n  );\n}\n\nfunction cleanRecord(obj) {\n  const out = {};\n  for (const [key, value] of Object.entries(obj)) {\n    out[key] = typeof value === 'string' ? stripLeadingEquals(value) : value;\n  }\n  return out;\n}\n\nconst monthMap = {\n  jan: '01', febr: '02', márc: '03', ápr: '04',\n  máj: '05', jún: '06', júl: '07', aug: '08',\n  szept: '09', okt: '10', nov: '11', dec: '12'\n};\n\nfunction parseHungarianDate(rawDate) {\n  const safeDate = stripLeadingEquals(rawDate);\n  const cleanedDate = safeDate.replace(/\\./g, '');\n  const m = cleanedDate.match(/^(\\d{4})\\s+([^\\s]+)\\s+(\\d{1,2})$/i);\n  if (!m) return safeDate;\n  const year = m[1];\n  const month = monthMap[m[2].toLowerCase()] || '01';\n  const day = String(m[3]).padStart(2, '0');\n  return `${year}-${month}-${day}`;\n}\n\nconst now = new Date();\nconst downloadedAt = now.toISOString();\nconst downloadDate = new Intl.DateTimeFormat('sv-SE', {\n  timeZone: 'Europe/Budapest',\n  year: 'numeric', month: '2-digit', day: '2-digit'\n}).format(now);\n\nconst downloaderId = 'KGY';\nconst results = [];\n\nconst dailyBlocks = html.split(/<div[^>]*class=\"[^\"]*mec-agenda-date-wrap[^\"]*\"[^>]*>/i);\n\nfor (let i = 1; i < dailyBlocks.length; i++) {\n  const block = dailyBlocks[i];\n  const dayMatch  = block.match(/<span[^>]*class=\"[^\"]*mec-agenda-day[^\"]*\"[^>]*>([\\s\\S]*?)<\\/span>/i);\n  const dateMatch = block.match(/<span[^>]*class=\"[^\"]*mec-agenda-date[^\"]*\"[^>]*>([\\s\\S]*?)<\\/span>/i);\n  const day = dayMatch  ? decodeHtml(dayMatch[1])  : null;\n  const rawDate   = dateMatch ? decodeHtml(dateMatch[1]) : null;\n  const eventDate = rawDate   ? parseHungarianDate(rawDate) : null;\n\n  const events = block.split(/<div[^>]*class=\"[^\"]*mec-agenda-event[^\"]*\"[^>]*>/i);\n  for (let j = 1; j < events.length; j++) {\n    const evHtml = events[j];\n    const startMatch = evHtml.match(/<span[^>]*class=\"[^\"]*mec-start-time[^\"]*\"[^>]*>([\\s\\S]*?)<\\/span>/i);\n    const endMatch   = evHtml.match(/<span[^>]*class=\"[^\"]*mec-end-time[^\"]*\"[^>]*>([\\s\\S]*?)<\\/span>/i);\n    let eventUrl = '', title = '';\n    const linkMatch  = evHtml.match(/<a[^>]*href=\"([^\"]*)\"[^>]*>([\\s\\S]*?)<\\/a>/i);\n    if (linkMatch) {\n      eventUrl = decodeHtml(linkMatch[1]);\n      title    = decodeHtml(linkMatch[2].replace(/<[^>]+>/g, ''));\n    } else {\n      const titleMatch = evHtml.match(/<span[^>]*class=\"[^\"]*mec-agenda-event-title[^\"]*\"[^>]*>([\\s\\S]*?)<\\/span>/i)\n                      || evHtml.match(/<h[1-6][^>]*>([\\s\\S]*?)<\\/h[1-6]>/i);\n      if (titleMatch) title = decodeHtml(titleMatch[1].replace(/<[^>]+>/g, ''));\n    }\n    if (!title || title.trim() === '') continue;\n\n    const row = cleanRecord({\n      downloaded_at: downloadedAt,\n      download_date: downloadDate,\n      downloader_id: downloaderId,\n      source_url:    sourceUrl,\n      source_key:    sourceKey,\n      day:           day,\n      raw_date:      rawDate,\n      event_date:    eventDate,\n      start:         startMatch ? decodeHtml(startMatch[1]) : '',\n      end:           endMatch   ? decodeHtml(endMatch[1])   : '',\n      event_url:     eventUrl,\n      scrape_run_id: scrapeRunId,   // ← ez az új sor\n      title:         title\n    });\n    if (!row.event_url && row.title) {\n      row.event_url = 'nolink_' + row.event_date + '_' + row.title.substring(0, 20).replace(/\\s+/g, '-').toLowerCase();\n    }\n    results.push({ json: row });\n  }\n}\n\nreturn results;"
      },
