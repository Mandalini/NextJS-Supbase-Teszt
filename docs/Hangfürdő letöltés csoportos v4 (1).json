      "parameters": {
        "jsCode": "// =============================================\n// PARSER: other_parser (sablon a jövőre)\n// Kimenet: AZONOS struktúra!\n// =============================================\nconst html = $json.data || '';\nconst sourceItem = $('Loop Over Items').item.json;\nconst sourceUrl  = sourceItem.source_url || '';\nconst sourceKey  = sourceItem.source_key || 'unknown';\n\nconst now = new Date();\nconst downloadedAt = now.toISOString();\nconst downloadDate = new Intl.DateTimeFormat('sv-SE', {\n  timeZone: 'Europe/Budapest',\n  year: 'numeric', month: '2-digit', day: '2-digit'\n}).format(now);\nconst downloaderId = 'KGY';\n\n// TODO: ide kerül az oldal-specifikus parse logika\nconst results = [];\n\n// Kötelező mezők minden rekordban:\n// downloaded_at, download_date, downloader_id,\n// source_url, source_key, day, raw_date, event_date,\n// start, end, event_url, title\n\nreturn results;"
